# ─────────────────────────────────────────────────────────
# AGENT_Joko — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── Ollama (local) ──────────────────────────────────────
# URL of the local Ollama server.  Ignored on Railway
# unless you tunnel it.
OLLAMA_HOST=http://localhost:11434

# ── OpenRouter (cloud fallback / Railway primary) ────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI-compatible fallback (optional)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Groq (optional extra provider) ──────────────────────
# GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Dashboard ───────────────────────────────────────────
# HOST and PORT are set automatically on Railway via $PORT
# Override locally if needed:
# HOST=127.0.0.1
# PORT=8000

# ── Runtime behaviour ───────────────────────────────────
MODEL_WARMUP_ENABLED=false
OFFLINE_QUEUE_ENABLED=true
OFFLINE_QUEUE_REQUESTS=true
